# Flashoot Company Chatbot - Environment Configuration

# LLM provider keys. Add one or more comma-separated keys per provider.
GEMINI_API_KEYS=your_gemini_key_1,your_gemini_key_2
MISTRAL_API_KEYS=your_mistral_key
GROQ_API_KEYS=your_groq_key
OPENROUTER_API_KEYS=your_openrouter_key

# Default models. Change these if your account/provider supports different models.
GEMINI_MODEL=gemini-1.5-flash
MISTRAL_MODEL=mistral-small-latest
GROQ_MODEL=llama-3.1-8b-instant
OPENROUTER_MODEL=meta-llama/llama-3.1-8b-instruct

# OpenAI-compatible API base URLs.
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
MISTRAL_BASE_URL=https://api.mistral.ai/v1
GROQ_BASE_URL=https://api.groq.com/openai/v1
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Optional generation settings.
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=700

# Run mode:
# - cli: terminal chatbot
# - api: HTTP API for frontend (Render/local)
RUN_MODE=cli

# CORS settings for frontend origins.
# Use '*' for open access, or comma-separated URLs for stricter setup.
# Example:
# ALLOWED_ORIGINS=https://yourname.github.io,http://127.0.0.1:5500
ALLOWED_ORIGINS=*

# Basic API abuse protection.
# These limits are in-memory per backend instance and help reduce spam/API abuse.
MAX_REQUEST_BYTES=4096
MAX_MESSAGE_CHARS=500
RATE_LIMIT_REQUESTS=12
RATE_LIMIT_WINDOW_SECONDS=60
MIN_SECONDS_BETWEEN_REQUESTS=1.5

# Optional: Customize collection name
# QDRANT_COLLECTION=flashoot_company_data
# QDRANT_PATH=./qdrant_db_v3
# Auto-recreate Qdrant collection if embedding dimensions changed.
# Useful when switching from 768-dim mpnet to 384-dim MiniLM.
QDRANT_FORCE_RECREATE_ON_DIM_MISMATCH=true

# Optional: Customize embedding model
# Render/free-tier recommended default: faster startup and lower RAM usage.
# If you change the embedding model/dimension, reset Qdrant storage/rebuild indexes.
# EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
# EMBEDDING_DIM=384
